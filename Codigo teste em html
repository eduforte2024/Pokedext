<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokédex Suprema v3</title>
    <style>
        :root {
            --bg-main: #13131a;
            --bg-card: #1c1c24;
            --primary: #ef5350;
            --accent: #f1c40f;
            --text: #ffffff;
            --text-muted: #a0a0b5;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-main);
            color: var(--text);
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding-bottom: 90px;
            transition: background-color 0.4s ease;
        }

        header {
            background: linear-gradient(135deg, #1f1f2e, #13131a);
            width: 100%;
            padding: 18px 0;
            text-align: center;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.4);
            border-bottom: 2px solid var(--primary);
        }

        .container {
            padding: 20px;
            width: 95%;
            max-width: 480px;
            box-sizing: border-box;
        }

        .hidden { display: none !important; }

        .search-container {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
        }

        input {
            flex: 1;
            padding: 12px 15px;
            border-radius: 10px;
            border: 2px solid #2c2c38;
            background-color: #1c1c24;
            color: white;
            font-size: 16px;
            outline: none;
        }

        input:focus { border-color: var(--primary); }

        button {
            padding: 12px 20px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-size: 15px;
            font-weight: bold;
            transition: all 0.2s ease;
        }

        button:active { transform: scale(0.95); }

        .btn-primary { background-color: var(--primary); color: white; }
        .btn-accent { background-color: var(--accent); color: #13131a; }
        .btn-random { 
            background: linear-gradient(135deg, #9b59b6, #8e44ad); 
            color: white; 
            width: 100%; 
            margin-bottom: 20px; 
            font-size: 16px;
            padding: 15px;
            box-shadow: 0 4px 10px rgba(155, 89, 182, 0.3);
        }
        .btn-clear { background-color: #e74c3c; color: white; margin-bottom: 15px; width: 100%; }

        .zone-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-top: 10px;
        }
        .btn-zone {
            padding: 25px 15px;
            font-size: 16px;
            color: white;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .navigation-controls {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 20px;
        }
        .btn-nav {
            flex: 1;
            background-color: #2c2c38;
            color: white;
            font-size: 16px;
            border: 1px solid #3e3e52;
        }
        .btn-nav:hover { background-color: #3e3e52; }

        .card {
            background-color: var(--bg-card);
            padding: 25px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            border: 1px solid #2c2c38;
            margin-top: 10px;
        }

        .animated-image {
            width: 160px;
            height: 160px;
            animation: bounceIn 1s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes bounceIn {
            0% { transform: scale(0.3); opacity: 0; }
            50% { transform: scale(1.1); }
            80% { transform: scale(0.9); }
            100% { transform: scale(1); opacity: 1; }
        }

        .poke-name {
            font-size: 26px;
            font-weight: bold;
            margin: 15px 0 5px 0;
            letter-spacing: 1px;
        }

        .poke-info {
            font-size: 16px;
            opacity: 0.9;
            margin: 5px 0;
        }

        .pokemon-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-top: 10px;
        }

        .poke-mini-card {
            background-color: var(--bg-card);
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            border: 1px solid #2c2c38;
            transition: transform 0.2s, border-color 0.2s;
        }

        .poke-mini-card:hover {
            transform: translateY(-3px);
            border-color: var(--primary);
        }

        .poke-mini-card img { width: 80px; height: 80px; }
        .poke-mini-card div { font-weight: bold; text-transform: capitalize; margin-top: 5px; }

        .list-box {
            background-color: var(--bg-card);
            padding: 15px;
            border-radius: 12px;
            max-height: 300px;
            overflow-y: auto;
            border: 1px solid #2c2c38;
        }

        .log-item {
            background-color: rgba(0, 0, 0, 0.3);
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 8px;
            font-size: 14px;
            text-align: left;
            border-left: 4px solid var(--accent);
        }

        .fav-item {
            background-color: var(--bg-card);
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            border: 1px solid #2c2c38;
        }
        .fav-avatar { width: 65px; height: 65px; }
        .fav-info { flex: 1; margin-left: 12px; text-align: left; }
        .fav-name { font-weight: bold; font-size: 16px; text-transform: uppercase;}
        .fav-nickname { color: var(--accent); font-size: 14px; margin: 2px 0; font-weight: bold; }
        .fav-type { color: var(--text-muted); font-size: 12px; }
        .fav-actions button { padding: 6px 10px; font-size: 12px; width: 35px; margin-left: 5px; }

        .tab-bar {
            position: fixed;
            bottom: 0;
            width: 100%;
            background-color: #1c1c24;
            display: flex;
            justify-content: space-around;
            padding: 12px 0;
            box-shadow: 0 -4px 15px rgba(0,0,0,0.3);
            border-top: 1px solid #2c2c38;
            z-index: 100;
        }

        .tab-button {
            background: none;
            color: var(--text-muted);
            padding: 5px;
            font-size: 12px;
            font-weight: normal;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            width: auto;
            margin: 0;
        }

        .tab-button.active {
            color: var(--primary);
            font-weight: bold;
        }

        .tab-icon { font-size: 20px; }
        .loading { text-align: center; color: var(--accent); font-weight: bold; margin: 20px; }
    </style>
</head>
<body>

    <header id="header-title">Início - Pokédex</header>

    <div id="tab-content-home" class="container">
        <button class="btn-random" onclick="fetchRandomPokemon()">🎲 Roleta Pokémon Aleatória</button>
        
        <div class="navigation-controls">
            <button class="btn-nav" onclick="navigatePokemon(-1)">◀️ Voltar (ID-1)</button>
            <button class="btn-nav" onclick="navigatePokemon(1)">Avançar (ID+1) ▶️</button>
        </div>

        <div class="search-container">
            <input id="search-input" type="text" placeholder="Buscar por nome ou número...">
            <button class="btn-primary" onclick="searchPokemon()">Buscar</button>
        </div>

        <div id="home-loading" class="loading hidden">Carregando dados da API...</div>

        <div id="detail-card-area">
            <p style="color: var(--text-muted); font-style: italic; text-align: center; margin-top: 30px;">
                Use as setas, barra de pesquisa ou a roleta aleatória para carregar um Pokémon!
            </p>
        </div>
    </div>

    <div id="tab-content-zones" class="container hidden">
        <h3 style="margin-top: 0; text-align: center; color: var(--text-muted);">Roletas Elementais (Ambientes)</h3>
        <p style="text-align: center; font-size: 14px; color: var(--text-muted); margin-bottom: 20px;">Escolha um ambiente abaixo para sortear um Pokémon exclusivo cujo tipo principal seja o correspondente!</p>
        
        <div id="zone-loading" class="loading hidden">Sorteando no habitat...</div>

        <div class="zone-grid">
            <button class="btn-zone" style="background: linear-gradient(135deg, #ff5e62, #ff9966);" onclick="fetchZonePokemon('fire', 'Ambiente de Fogo')">
                <span>🔥</span> <span>Fogo</span>
            </button>
            <button class="btn-zone" style="background: linear-gradient(135deg, #2193b0, #6dd5ed);" onclick="fetchZonePokemon('water', 'Ambiente de Água')">
                <span>💧</span> <span>Água</span>
            </button>
            <button class="btn-zone" style="background: linear-gradient(135deg, #11998e, #38ef7d);" onclick="fetchZonePokemon('grass', 'Ambiente de Grama')">
                <span>🌿</span> <span>Grama</span>
            </button>
            <button class="btn-zone" style="background: linear-gradient(135deg, #f1c40f, #f39c12);" onclick="fetchZonePokemon('electric', 'Zona de Choque')">
                <span>⚡</span> <span>Elétrico</span>
            </button>
            <button class="btn-zone" style="background: linear-gradient(135deg, #9d7042, #cca070);" onclick="fetchZonePokemon('ground', 'Montanhas de Terra')">
                <span>⛰️</span> <span>Terra</span>
            </button>
            <button class="btn-zone" style="background: linear-gradient(135deg, #4ca1af, #c4e0e5);" onclick="fetchZonePokemon('flying', 'Altitudes do Ar')">
                <span>🍃</span> <span>Voador / Ar</span>
            </button>
        </div>
    </div>

    <div id="tab-content-list" class="container hidden">
        <h3 style="margin-top: 0; text-align: center; color: var(--text-muted);">Todos os Pokémons (API)</h3>
        <div id="list-loading" class="loading hidden">Carregando Catálogo...</div>
        <div id="main-pokemon-grid" class="pokemon-grid"></div>
    </div>

    <div id="tab-content-favorites" class="container hidden">
        <h3 style="margin-top: 0; text-align: center; color: var(--text-muted);">Meus Favoritos Salvos (Firebase)</h3>
        <div id="favorites-list"></div>
    </div>

    <div id="tab-content-history" class="container hidden">
        <h3 style="margin-top: 0; text-align: center; color: var(--text-muted);">Histórico de Consultas</h3>
        <button class="btn-clear" onclick="clearHistory()">🗑️ Limpar Histórico</button>
        <div id="history-box" class="list-box">
            <p style="color: var(--text-muted); text-align: center; font-style: italic;">Nenhuma atividade recente.</p>
        </div>
    </div>

    <div class="tab-bar">
        <button class="tab-button active" id="tab-home" onclick="switchTab('home')">
            <span class="tab-icon">🏠</span>
            <span>Início</span>
        </button>
        <button class="tab-button" id="tab-zones" onclick="switchTab('zones')">
            <span class="tab-icon">🗺️</span>
            <span>Zonas</span>
        </button>
        <button class="tab-button" id="tab-list" onclick="switchTab('list')">
            <span class="tab-icon">📜</span>
            <span>Lista</span>
        </button>
        <button class="tab-button" id="tab-favorites" onclick="switchTab('favorites')">
            <span class="tab-icon">⭐</span>
            <span>Favoritos</span>
        </button>
        <button class="tab-button" id="tab-history" onclick="switchTab('history')">
            <span class="tab-icon">📝</span>
            <span>Histórico</span>
        </button>
    </div>

    <script>
        let localFirebaseStorage = [];
        let currentPokemonData = null;
        let originalFormPokemonData = null; 
        let logs = [];
        let currentActiveId = 1; 

        const typeColors = {
            fire: "#aa3838", water: "#297bb8", grass: "#239a51",
            electric: "#ca9f0e", psychic: "#7d4694", normal: "#707a7a",
            bug: "#5d8233", poison: "#843282", ground: "#b89a4f",
            flying: "#846ec5", fighting: "#96241f", rock: "#91802b",
            ghost: "#594375", ice: "#74b1af", dragon: "#5424ca",
            steel: "#506060", fairy: "#ca7ca4"
        };

        window.onload = () => {
            loadInitialPokemonList();
            fetchPokemonById(1, false); 
        };

        function switchTab(tabName) {
            document.getElementById('tab-content-home').classList.add('hidden');
            document.getElementById('tab-content-zones').classList.add('hidden');
            document.getElementById('tab-content-list').classList.add('hidden');
            document.getElementById('tab-content-favorites').classList.add('hidden');
            document.getElementById('tab-content-history').classList.add('hidden');
            
            document.getElementById('tab-home').classList.remove('active');
            document.getElementById('tab-zones').classList.remove('active');
            document.getElementById('tab-list').classList.remove('active');
            document.getElementById('tab-favorites').classList.remove('active');
            document.getElementById('tab-history').classList.remove('active');

            if(tabName === 'home') {
                document.getElementById('tab-content-home').classList.remove('hidden');
                document.getElementById('tab-home').classList.add('active');
                document.getElementById('header-title').innerText = "Início - Pokédex";
            } else if(tabName === 'zones') {
                document.getElementById('tab-content-zones').classList.remove('hidden');
                document.getElementById('tab-zones').classList.add('active');
                document.getElementById('header-title').innerText = "Zonas de Habitat";
            } else if(tabName === 'list') {
                document.getElementById('tab-content-list').classList.remove('hidden');
                document.getElementById('tab-list').classList.add('active');
                document.getElementById('header-title').innerText = "Lista Completa";
            } else if(tabName === 'favorites') {
                document.getElementById('tab-content-favorites').classList.remove('hidden');
                document.getElementById('tab-favorites').classList.add('active');
                document.getElementById('header-title').innerText = "Favoritos";
                triggerRead();
            } else if(tabName === 'history') {
                document.getElementById('tab-content-history').classList.remove('hidden');
                document.getElementById('tab-history').classList.add('active');
                document.getElementById('header-title').innerText = "Histórico";
                renderHistory();
            }
        }

        function addLog(actionText) {
            const time = new Date().toLocaleTimeString();
            logs.unshift([${time}] ${actionText});
        }

        function renderHistory() {
            const container = document.getElementById('history-box');
            if(logs.length === 0) {
                container.innerHTML = '<p style="color: var(--text-muted); text-align: center; font-style: italic;">Nenhuma atividade recente.</p>';
                return;
            }
            container.innerHTML = logs.map(item => <div class="log-item">${item}</div>).join('');
        }

        function clearHistory() {
            if(confirm("Deseja mesmo apagar todo o histórico de consultas?")) {
                logs = [];
                renderHistory();
            }
        }

        function navigatePokemon(direction) {
            let targetId = currentActiveId + direction;
            if (targetId < 1) targetId = 1;
            if (targetId > 1010) targetId = 1010; 
            fetchPokemonById(targetId, true);
        }

        async function fetchPokemonById(idValue, logActivity = true) {
            const loader = document.getElementById('home-loading');
            loader.classList.remove('hidden');
            try {
                const res = await fetch(https://pokeapi.co/api/v2/pokemon/${idValue});
                const data = await res.json();
                originalFormPokemonData = data; 
                showPokemonDetails(data, true);
                if (logActivity) addLog(Navegou para o ID: ${data.id} (${data.name.toUpperCase()}));
            } catch (e) {
                console.error(e);
            } finally {
                loader.classList.add('hidden');
            }
        }

        // CORREÇÃO APLICADA AQUI: Filtro para purificar o ecossistema pelo tipo principal (slot 1)
        async function fetchZonePokemon(targetType, zoneName) {
            const loader = document.getElementById('zone-loading');
            loader.classList.remove('hidden');
            try {
                // Busca os Pokémons associados a este tipo
                const response = await fetch(https://pokeapi.co/api/v2/type/${targetType});
                const typeData = await response.json();
                
                const rawList = typeData.pokemon;
                if(rawList.length === 0) return alert("Nenhum Pokémon mapeado nesse habitat.");

                let attempts = 0;
                let foundValidPokemon = false;
                let data = null;

                // Tenta sortear e validar se o tipo principal condiz com o ambiente (máximo 15 tentativas para evitar loops)
                while (attempts < 15 && !foundValidPokemon) {
                    attempts++;
                    const randomIndex = Math.floor(Math.random() * rawList.length);
                    const chosenUrl = rawList[randomIndex].pokemon.url;

                    const resDetails = await fetch(chosenUrl);
                    data = await resDetails.json();

                    // Verifica se o tipo principal (índice 0 da array de tipos) é o tipo que queríamos
                    if (data.types && data.types[0].type.name === targetType) {
                        foundValidPokemon = true;
                    }
                }

                // Fallback de segurança: se o sorteio não achar um primário puro em 15 rodadas, pega o primeiro que der
                originalFormPokemonData = data;
                showPokemonDetails(data, true);
                addLog(Girou Roleta de Ambiente [${zoneName}]: "${data.name.toUpperCase()}");
                
                switchTab('home');
            } catch (error) {
                console.error(error);
                alert("Erro ao rodar a roleta do habitat elemental.");
            } finally {
                loader.classList.add('hidden');
            }
        }

        async function loadInitialPokemonList() {
            const grid = document.getElementById('main-pokemon-grid');
            const loader = document.getElementById('list-loading');
            loader.classList.remove('hidden');
            try {
                for(let i = 1; i <= 30; i++) {
                    const res = await fetch(https://pokeapi.co/api/v2/pokemon/${i});
                    const data = await res.json();
                    
                    const miniCard = document.createElement('div');
                    miniCard.className = 'poke-mini-card';
                    miniCard.onclick = () => {
                        originalFormPokemonData = data;
                        showPokemonDetails(data, true);
                        switchTab('home');
                    };
                    miniCard.innerHTML = `
                        <img src="${data.sprites.front_default}" alt="${data.name}">
                        <div style="text-transform: capitalize;">${data.name}</div>
                        <span style="font-size:11px; color:var(--text-muted)">Nº ${data.id}</span>
                    `;
                    grid.appendChild(miniCard);
                }
            } catch (e) {
                console.error(e);
            } finally {
                loader.classList.add('hidden');
            }
        }

        async function searchPokemon() {
            const val = document.getElementById('search-input').value.toLowerCase().trim();
            if(!val) return alert("Digite algo para buscar!");
            
            const loader = document.getElementById('home-loading');
            loader.classList.remove('hidden');
            
            try {
                const res = await fetch(https://pokeapi.co/api/v2/pokemon/${val});
                if(!res.ok) throw new Error();
                const data = await res.json();
                originalFormPokemonData = data;
                showPokemonDetails(data, true);
                addLog(Buscou por: "${data.name.toUpperCase()}");
                document.getElementById('search-input').value = '';
            } catch {
                alert("Pokémon não encontrado!");
                addLog(Falha na busca pelo termo: "${val}");
            } finally {
                loader.classList.add('hidden');
            }
        }

        async function fetchRandomPokemon() {
            const loader = document.getElementById('home-loading');
            loader.classList.remove('hidden');
            const randomId = Math.floor(Math.random() * 151) + 1;
            
            try {
                const res = await fetch(https://pokeapi.co/api/v2/pokemon/${randomId});
                const data = await res.json();
                originalFormPokemonData = data;
                showPokemonDetails(data, true);
                addLog(Sorteou na roleta geral: "${data.name.toUpperCase()}");
            } catch (e) {
                alert("Erro ao rodar a roleta.");
            } finally {
                loader.classList.add('hidden');
            }
        }

        async function showPokemonDetails(data, isBaseForm = true) {
            currentPokemonData = data;
            currentActiveId = data.id; 
            
            const targetArea = document.getElementById('detail-card-area');
            const mainType = data.types[0].type.name;
            document.body.style.backgroundColor = typeColors[mainType] || "#13131a";

            let actionButtonHtml = '';

            if (isBaseForm) {
                try {
                    const speciesRes = await fetch(data.species.url);
                    const speciesData = await speciesRes.json();
                    const evoRes = await fetch(speciesData.evolution_chain.url);
                    const evoData = await evoRes.json();

                    let currentEvo = evoData.chain;
                    let evoChainNames = [];
                    while (currentEvo) {
                        evoChainNames.push(currentEvo.species.name);
                        currentEvo = currentEvo.evolves_to[0];
                    }

                    const currentIndex = evoChainNames.indexOf(data.name);
                    if (currentIndex !== -1 && currentIndex < evoChainNames.length - 1) {
                        let nextEvoName = evoChainNames[currentIndex + 1];
                        actionButtonHtml = `
                            <button class="btn-primary" style="margin-top: 15px; width: 100%; background-color: #2ecc71;" onclick="fetchEvolutionForm('${nextEvoName}')">
                                🧬 Ver Evolução: ${nextEvoName.toUpperCase()} ➔
                            </button>
                        `;
                    } else {
                        actionButtonHtml = <p style="font-size:13px; color:var(--text-muted); margin-top:15px;">Este Pokémon não possui evoluções adicionais.</p>;
                    }
                } catch (err) {
                    actionButtonHtml = <p style="font-size:13px; color:var(--text-muted); margin-top:15px;">Evoluções não mapeadas.</p>;
                }
            } else {
                actionButtonHtml = `
                    <button class="btn-primary" style="margin-top: 15px; width: 100%; background-color: #34495e;" onclick="restoreBaseForm()">
                        ↩️ Voltar para Forma Base (${originalFormPokemonData.name.toUpperCase()})
                    </button>
                `;
            }

            const statsHtml = `
                <div style="display:flex; justify-content:space-around; background:rgba(0,0,0,0.3); padding:10px; border-radius:10px; margin: 15px 0; font-size:14px;">
                    <div>⚖️ <strong>Peso:</strong> ${data.weight / 10} kg</div>
                    <div>📏 <strong>Altura:</strong> ${data.height / 10} m</div>
                </div>
                <div style="font-size:14px; text-align:left; padding: 5px 10px; color: var(--text-muted);">
                    ⚡ <strong>Habilidade Principal:</strong> <span style="color:#fff; text-transform:capitalize;">${data.abilities[0].ability.name}</span>
                </div>
            `;

            targetArea.innerHTML = `
                <div class="card">
                    <img class="animated-image" src="${data.sprites.front_default}" alt="${data.name}">
                    <div class="poke-name">${data.name.toUpperCase()}</div>
                    <div class="poke-info"><strong>Número na Pokédex:</strong> Nº ${data.id}</div>
                    <div class="poke-info"><strong>Tipo:</strong> ${data.types.map(t => t.type.name.toUpperCase()).join(' / ')}</div>
                    
                    ${statsHtml}
                    ${actionButtonHtml}

                    <button class="btn-accent" style="margin-top: 20px; width: 100%;" onclick="triggerCreate()">⭐ Salvar nos Favoritos</button>
                </div>
            `;
        }

        async function fetchEvolutionForm(name) {
            const loader = document.getElementById('home-loading');
            loader.classList.remove('hidden');
            try {
                const res = await fetch(https://pokeapi.co/api/v2/pokemon/${name});
                const data = await res.json();
                showPokemonDetails(data, false); 
                addLog(Visualizou avanço evolutivo de: "${data.name.toUpperCase()}");
            } catch (e) {
                alert("Erro ao carregar forma evoluída.");
            } finally {
                loader.classList.add('hidden');
            }
        }

        function restoreBaseForm() {
            if (originalFormPokemonData) {
                showPokemonDetails(originalFormPokemonData, true);
                addLog(Retornou para forma base: "${originalFormPokemonData.name.toUpperCase()}");
            }
        }

        // --- OPERAÇÕES CRUD DO FIREBASE SIMULADO ---

        function triggerCreate() {
            if(!currentPokemonData) return;
            
            const exists = localFirebaseStorage.some(p => p.pokeId === currentPokemonData.id);
            if(exists) return alert("Esse Pokémon já está nos favoritos!");

            const newFav = {
                id: Date.now().toString(),
                pokeId: currentPokemonData.id,
                nome: currentPokemonData.name,
                apelido: currentPokemonData.name.toUpperCase(),
                imagem: currentPokemonData.sprites.front_default,
                tipo: currentPokemonData.types[0].type.name
            };

            localFirebaseStorage.push(newFav);
            addLog(Adicionou aos favoritos: "${newFav.nome.toUpperCase()}");
            alert(${newFav.nome.toUpperCase()} salvo com sucesso!);
            switchTab('favorites');
        }

        function triggerRead() {
            const list = document.getElementById('favorites-list');
            list.innerHTML = '';

            if(localFirebaseStorage.length === 0) {
                list.innerHTML = '<p style="color:var(--text-muted); text-align:center; font-style:italic; margin-top:30px;">Sua lista de favoritos está vazia.</p>';
                return;
            }

            localFirebaseStorage.forEach(item => {
                list.innerHTML += `
                    <div class="fav-item">
                        <img src="${item.imagem}" class="fav-avatar" alt="${item.nome}">
                        <div class="fav-info">
                            <div class="fav-name">${item.nome}</div>
                            <div class="fav-nickname">"${item.apelido}"</div>
                            <div class="fav-type">Tipo: ${item.tipo}</div>
                        </div>
                        <div class="fav-actions">
                            <button class="btn-primary" style="background-color:#2980b9;" onclick="triggerUpdate('${item.id}', '${item.apelido}')">✏️</button>
                            <button class="btn-primary" style="background-color:#c0392b;" onclick="triggerDelete('${item.id}')">🗑️</button>
                        </div>
                    </div>
                `;
            });
        }

        function triggerUpdate(id, currentNick) {
            const newNick = prompt("Insira um apelido customizado para salvar no Firebase:", currentNick);
            if(newNick && newNick.trim() !== "") {
                const index = localFirebaseStorage.findIndex(p => p.id === id);
                if(index !== -1) {
                    const oldNick = localFirebaseStorage[index].apelido;
                    localFirebaseStorage[index].apelido = newNick.trim();
                    addLog(Mudou apelido de "${oldNick}" para "${newNick.trim()}");
                    triggerRead();
                }
            }
        }

        function triggerDelete(id) {
            if(confirm("Remover este Pokémon da sua lista do Firebase?")) {
                const item = localFirebaseStorage.find(p => p.id === id);
                if(item) addLog(Removeu dos favoritos: "${item.nome.toUpperCase()}");
                localFirebaseStorage = localFirebaseStorage.filter(p => p.id !== id);
                triggerRead();
            }
        }
    </script>
</body>
</html>
